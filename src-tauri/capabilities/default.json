{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:scope-appdata-recursive",
    "android-webview:default",
    "android-webview:allow-save-backup-to-downloads",
    "android-webview:allow-load-backup-from-downloads",
    "android-webview:allow-export-cookies-for-backup",
    "android-webview:allow-import-cookies-from-backup",
    "android-webview:allow-set-haptic",
    "android-webview:allow-set-tap-sound",
    "android-webview:allow-trigger-haptic"
  ]
}
