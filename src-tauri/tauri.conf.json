{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SocialGlowz",
  "version": "0.1.0",
  "identifier": "com.socialglowz.desktop",
  "build": {
    "frontendDist": "../dist/tauri",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm tauri:dev",
    "beforeBuildCommand": "pnpm tauri:build"
  },
  "app": {
    "windows": [
      {
        "title": "SocialGlowz",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "socialglowz"
          ],
          "host": "auth-callback",
          "pathPrefix": [
            "/oauth"
          ]
        },
        {
          "scheme": [
            "https"
          ],
            "host": "socialglowz.com",
          "pathPrefix": [
            "/auth/callback"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
