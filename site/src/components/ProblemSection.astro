---
const problems = [
  {
    icon: '🔐',
    title: 'Session Sprawl',
    description: 'Personal, client, and team accounts collide in the same browser. Logging out becomes part of the job instead of an exception.',
    wide: true,
  },
  {
    icon: '🌐',
    title: 'Network Hopping',
    description: 'Every network has its own tab, app, rules, and distractions. Switching tasks means rebuilding context again and again.',
  },
  {
    icon: '🎯',
    title: 'Feed Distractions',
    description: 'Suggestions, sponsored posts, and infinite feeds pull attention away from the task you opened the network to complete.',
  },
  {
    icon: '📋',
    title: 'Scattered Planning',
    description: 'Content ideas, links, and follow-up work live outside the place where you actually execute social workflows.',
  },
]
---

<section class="py-16 sm:py-24 bg-card">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 sm:mb-16" data-reveal>
      <h2
        class="animate-fade-up text-3xl sm:text-4xl font-bold text-foreground mb-4"
        style="font-family: var(--font-instrument-sans);"
      >
        Social Work Is Split Across Too Many Surfaces
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-reveal>
      {problems.map((problem, index) => (
        <div
          class={`animate-fade-up delay-${(index + 1) * 100} group relative p-6 rounded-2xl bg-background border border-border hover:border-foreground/25 hover:scale-[1.02] transition-all duration-300 ${
            problem.wide ? 'md:col-span-2' : ''
          }`}
        >
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl sm:text-4xl">{problem.icon}</span>
            <h3 class="text-xl sm:text-2xl font-semibold text-foreground">{problem.title}</h3>
          </div>
          <p class="text-base text-muted-foreground leading-relaxed">{problem.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
