          <!-- Profile organizer animation -->
          <div class="hidden sm:block w-[260px] shrink-0" id="playlist-organizer">
            <div class="flex flex-col gap-1" id="playlist-unsorted">
              <div class="flex items-center gap-2 px-2 py-1 rounded-md bg-muted/50">
