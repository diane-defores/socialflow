        </p>
        <div class="flex items-center gap-2 mb-4">
          <span class="px-2 py-1 text-xs bg-muted rounded text-muted-foreground">Local</span>
          <span class="px-2 py-1 text-xs bg-muted rounded text-muted-foreground">Encrypted backup</span>
          <span class="px-2 py-1 text-xs bg-muted rounded text-muted-foreground">Profile scoped</span>
        </div>
        <span class="inline-block bg-foreground/10 text-foreground rounded-full px-3 py-1 text-sm">Sessions stay local</span>
      </div>
    </div>
  </div>
</section>

<script>
  // Keyboard shortcut press animation
  const keys = document.querySelectorAll<HTMLElement>('.kbd-key')
  setInterval(() => {
    keys.forEach((key, i) => {
      setTimeout(() => {
        key.style.transform = 'scale(0.95) translateY(2px)'
        setTimeout(() => {
          key.style.transform = ''
        }, 200)
      }, i * 50)
    })
  }, 3000)
</script>
