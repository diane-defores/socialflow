---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import { contactEmail, siteUrl } from '../config/site'

const privacyEmail = contactEmail('privacy')

const jsonLd = [{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl('/') },
    { "@type": "ListItem", position: 2, name: "Privacy Policy", item: siteUrl('/privacy') },
  ],
}]
---

<Layout title="Privacy Policy - SocialFlow" description="Learn how SocialFlow collects, uses, and protects your personal information." path="/privacy" jsonLd={jsonLd}>
  <main id="main-content" class="min-h-screen bg-background text-foreground">
    <Navbar />
    <div class="max-w-4xl mx-auto px-4 pt-32 pb-16">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">Privacy Policy</h1>
      <p class="mt-4 text-muted-foreground">Last updated: February 2026</p>

      <div class="mt-8 space-y-8">
        <section>
          <h2 class="text-xl font-semibold text-foreground">1. Information We Collect</h2>
          <p class="mt-3 text-muted-foreground">When you use SocialFlow, we collect information you provide directly to us, including:</p>
          <ul class="mt-3 list-disc space-y-2 pl-6 text-muted-foreground">
            <li>Account information (name, email address) when you sign up</li>
            <li>Preferences and settings you configure</li>
            <li>Profile and network link configuration</li>
            <li>Feature usage and app crash diagnostics</li>
          </ul>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-foreground">2. How We Use Your Information</h2>
          <p class="mt-3 text-muted-foreground">We use the information we collect to:</p>
          <ul class="mt-3 list-disc space-y-2 pl-6 text-muted-foreground">
            <li>Provide, maintain, and improve our services</li>
            <li>Store and sync your profiles and preferences across devices</li>
            <li>Send you technical notices and support messages</li>
            <li>Respond to your comments and questions</li>
          </ul>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-foreground">3. Cookies and Sessions</h2>
          <p class="mt-3 text-muted-foreground">SocialFlow stores live social cookies locally on your device by design. Synchronization applies only to app preferences and configuration.</p>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-foreground">4. Data Security</h2>
          <p class="mt-3 text-muted-foreground">We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction. Your data is stored securely using industry-standard encryption.</p>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-foreground">5. Data Retention</h2>
          <p class="mt-3 text-muted-foreground">We retain your information for as long as your account is active or as needed to provide you services. You can delete your account and associated data at any time through your account settings.</p>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-foreground">6. Your Rights</h2>
          <p class="mt-3 text-muted-foreground">You have the right to access, correct, or delete your personal information. You can request exported data or account deletion by contacting us.</p>
        </section>
        <section>
          <h2 class="text-xl font-semibold text-foreground">7. Contact Us</h2>
          <p class="mt-3 text-muted-foreground">If you have questions about this Privacy Policy, please contact us at <a href={`mailto:${privacyEmail}`} class="text-foreground underline underline-offset-4 hover:opacity-80">{privacyEmail}</a>.</p>
        </section>
      </div>

      <section class="mt-12 border-t border-border pt-8">
        <h2 class="text-lg font-semibold text-foreground">Related Pages</h2>
        <ul class="mt-4 flex flex-wrap gap-4">
          <li><a href="/terms" class="text-foreground underline underline-offset-4 hover:opacity-80">Terms of Service</a></li>
          <li><a href="/features" class="text-foreground underline underline-offset-4 hover:opacity-80">Features</a></li>
          <li><a href="/blog" class="text-foreground underline underline-offset-4 hover:opacity-80">Blog</a></li>
        </ul>
      </section>
    </div>
    <Footer />
  </main>
</Layout>
